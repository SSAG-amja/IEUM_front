{
  "expo": {
    "name": "IEUM",
    "slug": "IEUM",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ieum",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "이음이 목적지 음성 입력을 위해 마이크를 사용하도록 허용합니다.",
        "NSSpeechRecognitionUsageDescription": "이음이 목적지 음성을 텍스트로 변환하도록 허용합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.IEUM",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "이음이 접근성 경로 안내를 위해 현재 위치를 사용하도록 허용합니다."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "이음이 목적지 음성 입력을 위해 마이크를 사용하도록 허용합니다."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "이음이 목적지 음성 입력을 위해 마이크를 사용하도록 허용합니다.",
          "speechRecognitionPermission": "이음이 목적지 음성을 텍스트로 변환하도록 허용합니다."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ae07d05-21b8-4882-a611-2e94df5e3cf2"
      }
    }
  }
}
